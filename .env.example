# LLM provider selection
LLM_PROVIDER=anthropic
LLM_MODEL=

# Optional: separate provider/model for screenshot parsing
# Example: keep text on Groq, but use Anthropic for vision
VLM_PROVIDER=
VLM_MODEL=

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_key_here

# Groq API
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional: for Bilibili/NGA scraping
NGA_COOKIE=
BILIBILI_SESSDATA=
